# =============================================================================
# STURDY APP - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (KEEP SECRET - server-side only)
# Used for admin operations and bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Used for: Script generation (SOS + What If modes)
# Cost: ~$0.0004 per script with GPT-4o-mini
OPENAI_API_KEY=sk-your_openai_api_key_here

# -----------------------------------------------------------------------------
# Upstash Redis - Rate Limiting (Required for Production)
# -----------------------------------------------------------------------------
# Get free tier from: https://console.upstash.com/
# Used for: API rate limiting to prevent abuse and cost overruns
# Limits: 5 requests/hr (free), 100 requests/hr (pro), 1000 requests/hr (family)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# -----------------------------------------------------------------------------
# Stripe (Optional - Phase 2 Monetization)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Your app's public URL (used for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# -----------------------------------------------------------------------------
# Sentry DSN (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# PostHog API Key (analytics)
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
# Set to 'development' for local dev, 'production' for deployed app
NODE_ENV=development

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Create Supabase project: https://supabase.com/dashboard
# 2. Create OpenAI account: https://platform.openai.com/
# 3. Create Upstash Redis: https://console.upstash.com/
# 4. Copy this file to .env.local
# 5. Fill in all required values
# 6. Run: npm install
# 7. Run: npm run dev
# 8. Visit: http://localhost:3000
#
# For production deployment on Vercel:
# 1. Add all environment variables to Vercel dashboard
# 2. Deploy from main branch
# 3. Verify all features work on production URL
# =============================================================================

